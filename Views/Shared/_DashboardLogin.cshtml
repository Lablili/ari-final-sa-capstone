<section class="login-screen" id="loginScreen">
    <div class="login-card">
        <p class="login-eyebrow">Secure Access</p>
        <h1>Bantay Dagat</h1>
        <p class="login-copy">Enter the password to access the coastal monitoring dashboard.</p>

        <form class="login-form" id="loginForm">
            <label class="form-label" for="password">Password</label>
            <input class="form-input" id="password" name="password" type="password" placeholder="Enter password" required>
            <p class="form-error" id="loginError" aria-live="polite"></p>
            <button class="login-button" type="submit">Log In</button>
        </form>
    </div>
</section>
